@model LMS.Models.BorrowRecord
@{
    ViewData["Title"] = "Borrow Book";
}

<h2>Borrow @ViewBag.BookTitle</h2>

<form asp-action="Borrow" method="post">

    <input type="hidden" asp-for="BookId" />

    <div>
        <label asp-for="StudentName"></label>
        <input asp-for="StudentName" />
        <span asp-validation-for="StudentName"></span>
    </div>

    <div>
        <label asp-for="DueDate"></label>
        <input asp-for="DueDate" type="date" />
    </div>

    <div>
        <label asp-for="ReturnDate"></label>
        <input asp-for="ReturnDate" type="date" />
    </div>

    <button type="submit">Borrow</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}